if __name__ == '__main__':
    students = []

for _ in range(int(input())):
    name = input()
    score = float(input())
    students.append([name, score])

scores = sorted({s[1] for s in students})
second_num = scores[1]

for name in sorted(s[0] for s in students if s[1] == second_num):
    print(name)
    
